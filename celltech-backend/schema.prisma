// celltech-backend/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum QualityGrade {
  OEM
  Premium
  Aftermarket
}

// --- TABLES (MODELS) ---

model Brand {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  
  // Relations: A brand can have many models
  models  Model[]
}

model Model {
  id             Int     @id @default(autoincrement())
  brandId        Int
  modelNumber    String  @unique
  marketingName  String?
  releaseYear    Int?

  // Relations
  brand          Brand              @relation(fields: [brandId], references: [id])
  inventory      Inventory[]        // Parts directly linked to this specific phone
  compatibilities CompatibilityMap[] // Parts linked via the cross-compatibility mapping table
}

model Category {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  
  // Relations: A category has many inventory items
  inventory Inventory[]
}

model Inventory {
  skuId          String        @id
  modelId        Int?          // Optional: Left blank if it's a cross-compatible part
  categoryId     Int
  partName       String?
  specifications String?
  qualityGrade   QualityGrade?
  wholesalePrice Int?          // Stored in cents (e.g., 2500 = $25.00)
  stockLevel     Int           @default(0)

  // Relations
  model           Model?             @relation(fields: [modelId], references: [id])
  category        Category           @relation(fields: [categoryId], references: [id])
  compatibilities CompatibilityMap[] 
}

model CompatibilityMap {
  id                Int    @id @default(autoincrement())
  skuId             String
  compatibleModelId Int

  // Relations
  inventory         Inventory @relation(fields: [skuId], references: [skuId])
  model             Model     @relation(fields: [compatibleModelId], references: [id])

  @@unique([skuId, compatibleModelId]) // Prevent duplicate mappings
}
